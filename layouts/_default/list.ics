BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Place//OSSCAMEROON//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
{{- range sort .Pages "Date" "asc" }}
{{- $active := true }}
{{- /* TODO: Should us send only active events? */ -}}
{{- /* {{- $active := false }} */ -}}
{{- /* {{- if .Params.end_date }} */ -}}
{{- /*   {{- if ge (time .Params.end_date) now }}{{ $active = true }}{{ end }} */ -}}
{{- /* {{- else }} */ -}}
{{- /*   {{- if ge .Date now }}{{ $active = true }}{{ end }} */ -}}
{{- /* {{- end }} */ -}}
{{- if $active }}
BEGIN:VEVENT
UID:{{ md5 (printf "%s-%s" .Params.slug (.Date.Format "2006-01-02")) }}
DTSTAMP:{{ now.UTC.Format "20060102T150405Z" }}
DTSTART:{{ .Date.UTC.Format "20060102T150405Z" }}
{{- if .Params.end_date }}
DTEND:{{ (time .Params.end_date).UTC.Format "20060102T150405Z" }}
{{- else }}
DURATION:PT1H
{{- end }}
LAST-MODIFIED:{{ .Lastmod.UTC.Format "20060102T150405Z" }}
STATUS:{{ with .Params.status }}{{ . | upper }}{{ else }}CONFIRMED{{ end }}
SUMMARY:{{ .Params.title }}
DESCRIPTION:{{ .Params.description }}
LOCATION:{{ .Params.location }}
URL:{{ .Permalink }}
{{- if .Params.organizer_name }}
ORGANIZER;CN={{ .Params.organizer_name }}{{ with .Params.organizer_email }}:mailto:{{ . }}{{ end }}
{{- end }}
{{- if .Params.categories }}
CATEGORIES:{{ delimit .Params.categories "," }}
{{- end }}
{{- if .Params.image }}
ATTACH:{{ .Params.image }}
{{- end }}
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:{{ .Params.title }}
TRIGGER:-P1D
END:VALARM
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:{{ .Params.title }}
TRIGGER:-PT1H
END:VALARM
END:VEVENT
{{- end }}
{{- end }}
END:VCALENDAR
